                    "type": "string",
                    "description": "ID of the owner"
                },
                "amenities": {
                    "type": "array",
                    "description": "List of amenities ID's",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "type": "object"
        },
        "PlaceUpdate": {
            "properties": {
